# === Monorepo root .gitignore ===

# IDE settings
.idea/
.vscode/
*.swp
*.swo
.zcode/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Test artifacts
*.test
*.out
coverage.txt
*.coverprofile

# Go workspace files
go.work
go.work.sum

# Project planning docs (internal notes, not part of the shipped codebase)
/backend/docs/
/frontend/docs/
*.txt

# Scratch / test files at repo root
TEST.png
*.local

# Frontend — Node / Vite
node_modules/
dist/
dist-ssr/

# Frontend — environment & secrets
.env
.env.*
!.env.example

# Frontend — scaffolded boilerplate we don't track
frontend/.oxlintrc.json
frontend/README.md

# Frontend — misc
*.log
npm-debug.log*
